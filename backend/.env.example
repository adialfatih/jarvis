# ===== Jarvis Agent — contoh konfigurasi =====
# Copy jadi .env lalu isi. JANGAN commit file .env.

# Wajib: token rahasia untuk auth API. Generate misal dengan:
#   python -c "import secrets; print(secrets.token_hex(24))"
JARVIS_AUTH_TOKEN=

# Nama mesin di app HP & prefix Telegram, contoh: Laptop-Win10 / PC-Ubuntu
JARVIS_MACHINE_NAME=

# Telegram bot — PENTING: satu bot hanya boleh dipakai SATU mesin
# (long polling getUpdates konflik jika dipakai 2 agent). Buat bot per mesin
# via @BotFather. chat_id sama untuk semua bot (id akun kamu).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Root folder project, pisahkan dengan ; jika lebih dari satu
# Windows contoh: PROJECT_ROOTS=C:\xampp\htdocs;D:\_2026
# Linux contoh:   PROJECT_ROOTS=/home/user/_2026
PROJECT_ROOTS=

# Voice input Whisper (butuh package faster-whisper)
WHISPER_ENABLED=true
WHISPER_MODEL_SIZE=small
# Windows contoh: WHISPER_MODEL_PATH=D:\whisper-models
#WHISPER_MODEL_PATH=

# Override command engine jika tidak ada di PATH
#ENGINE_CLAUDE_CMD=claude
#ENGINE_CODEX_CMD=codex
